<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content">
                <div class="container py-4">
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <%- message %>
                                <div class="card shadow border-0 rounded-4">
                                    <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                                        <h4 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill"></i> THÊM TÀI KHOẢN
                                            MỚI</h4>
                                    </div>
                                    <div class="card-body p-4">
                                        <form action="/taikhoan/them" method="POST">
                                            <div class="mb-3">
                                                <label class="form-label fw-bold">Họ và tên</label>
                                                <input type="text" name="tenTaiKhoan" class="form-control"
                                                    placeholder="Nhập tên nhân viên hoặc khách hàng..." required>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                                <input type="text" name="tenDangNhap" class="form-control"
                                                    placeholder="Ví dụ: nhanvien_agu" required>
                                            </div>

                                            <div class="row mb-3">
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Quyền hạn</label>
                                                    <select name="quyenHan" class="form-select border-primary-subtle">
                                                        <option value="2">Nhân viên bán hàng</option>
                                                        <option value="1">Quản trị viên (Admin)</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Trạng thái</label>
                                                    <select name="khoa" class="form-select">
                                                        <option value="1">Hoạt động</option>
                                                        <option value="0">Khóa tài khoản</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="row mb-4">
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Mật khẩu</label>
                                                    <input type="password" name="matKhau" class="form-control"
                                                        placeholder="Mật khẩu ban đầu" required>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Nhập lại mật khẩu</label>
                                                    <input type="password" name="xacNhanMatKhau" class="form-control"
                                                        placeholder="Xác nhận lại" required>
                                                </div>
                                            </div>

                                            <div class="d-grid gap-2">
                                                <button type="submit"
                                                    class="btn btn-primary btn-lg rounded-pill shadow fw-bold">
                                                    <i class="bi bi-save"></i> LƯU TÀI KHOẢN
                                                </button>
                                                <a href="/taikhoan" class="btn btn-outline-secondary rounded-pill">QUAY
                                                    LẠI DANH SÁCH</a>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="footer">
                <%- include('footer') %>
            </div>
    </div>
</body>

<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>