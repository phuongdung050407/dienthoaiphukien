<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %> - MAPD Tech Space
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content">
                <div id="cottrai"></div>

                <div id="phangiua" class="container-fluid"
                    style="background-color: white; border-radius: 15px; padding: 30px; margin-top: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb"
                            style="background: #f8f9fa; border: none; padding: 10px 15px; border-radius: 10px;">
                            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
                            <li class="breadcrumb-item active" aria-current="page">
                                <%= loai==='dienthoai' ? 'Điện thoại' : 'Phụ kiện' %>
                            </li>
                        </ol>
                    </nav>

                    <h3 class="text-primary fw-bold mb-4 border-bottom pb-3">
                        <i class="bi bi-tags-fill"></i>
                        <%= title %>
                    </h3>

                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                        <% if (danhSach && danhSach.length> 0) { %>
                            <% danhSach.forEach(item=> { %>
                                <div class="col">
                                    <div class="card h-100 shadow-sm border-0 product-card position-relative bg-white">
                                        <a href="/sanpham/chitiet/<%= item._id %>/<%= loai %>"
                                            class="text-decoration-none text-dark d-flex flex-column h-100">

                                            <div class="product-img-wrapper">
                                                <img src="/images/<%= item.hinhAnh %>" class="card-img-top product-img"
                                                    alt="<%= item.tenDienThoai || item.tenPhuKien %>">
                                            </div>

                                            <div class="card-body text-center pt-0 flex-grow-1">
                                                <h6 class="card-title fw-bold mb-2">
                                                    <%= item.tenDienThoai || item.tenPhuKien %>
                                                </h6>

                                                <div class="price-box mb-2">
                                                    <div class="text-danger fw-bold fs-5">
                                                        <%= item.giaBan.toLocaleString() %> đ
                                                    </div>
                                                    <% if (item.giaGoc> item.giaBan) { %>
                                                        <small class="text-muted text-decoration-line-through">
                                                            <%= item.giaGoc.toLocaleString() %> đ
                                                        </small>
                                                        <% } %>
                                                </div>

                                                <div class="mt-2">
                                                    <% if (loai==='dienthoai' ) { %>
                                                        <span
                                                            class="badge bg-light text-dark border-secondary-subtle border small">
                                                            <%= item.boNho %> | <%= item.dungLuongPin %>
                                                        </span>
                                                        <% } else { %>
                                                            <span
                                                                class="badge bg-light text-primary border-primary-subtle border small">
                                                                Phụ kiện chính hãng
                                                            </span>
                                                            <% } %>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class="col-12">
                                            <div class="alert alert-light text-center border py-5 shadow-sm rounded-4">
                                                <i class="bi bi-inbox fs-2 d-block mb-3"></i>
                                                Hiện chưa có sản phẩm nào trong danh mục này.
                                            </div>
                                        </div>
                                        <% } %>
                    </div>
                </div>
                <div id="cotphai"></div>
            </div>

            <%- include('footer') %>
    </div>
</body>
<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }

    /* CSS đồng bộ toàn hệ thống MAPD Tech Space */
    .product-card {
        transition: all 0.3s ease;
        border-radius: 20px !important;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1) !important;
    }

    .product-img-wrapper {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background-color: #fff;
    }

    .product-img {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.08);
    }

    .card-title {
        height: 3rem;
        overflow: hidden;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        font-size: 1.05rem;
        line-height: 1.5;
    }

    .price-box {
        min-height: 3.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>