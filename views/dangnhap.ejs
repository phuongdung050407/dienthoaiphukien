<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content">
                <div class="container">
                    <div class="row justify-content-center align-items-center mt-5">
                        <div class="col-md-5 col-lg-4">

                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-primary"><img src="/images/1.jpg" style="max-width:280px;"></h2>
                                <p class="text-muted small">Hệ thống bán lẻ điện thoại & phụ kiện</p>
                            </div>

                            <%- message %>

                                <div class="card shadow-lg border-0 rounded-4">
                                    <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                                        <h4 class="mb-0 fw-bold">ĐĂNG NHẬP</h4>
                                    </div>
                                    <div class="card-body p-4">
                                        <form action="/dangnhap" method="post">
                                            <div class="mb-3">
                                                <label class="form-label fw-bold small">Tên đăng nhập</label>
                                                <div class="input-group">
                                                    <span class="input-group-text bg-light"><i
                                                            class="bi bi-person"></i></span>
                                                    <input type="text" name="tenDangNhap" class="form-control" required
                                                        placeholder="Tên đăng nhập...">
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label fw-bold small">Mật khẩu</label>
                                                <div class="input-group">
                                                    <span class="input-group-text bg-light"><i
                                                            class="bi bi-lock"></i></span>
                                                    <input type="password" name="matKhau" class="form-control" required
                                                        placeholder="Nhập mật khẩu...">
                                                </div>
                                            </div>

                                            <div class="d-grid mt-4">
                                                <button type="submit"
                                                    class="btn btn-primary btn-lg rounded-pill shadow-sm">
                                                    Đăng nhập ngay
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <div class="text-center mt-3">
                                    <a href="/" class="text-secondary small text-decoration-none">
                                        <i class="bi bi-arrow-left"></i> Quay lại Trang chủ
                                    </a>
                                </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('footer') %>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>