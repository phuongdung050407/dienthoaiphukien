<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Thao tác thành công - MAPD Tech Space</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-light">
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content" class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-6 text-center">
                        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                            <div class="card-header bg-success text-white py-3">
                                <h4 class="mb-0 fw-bold"><i class="bi bi-check-circle-fill"></i>
                                    <%= title %>
                                </h4>
                            </div>
                            <div class="card-body p-5">
                                <div class="mb-4">
                                    <i class="bi bi-patch-check text-success" style="font-size: 5rem;"></i>
                                </div>

                                <div class="mb-4 fs-5 fw-bold text-dark">
                                    <%- message || "Thao tác của bạn đã được hệ thống ghi nhận thành công!" %>
                                </div>

                                <p class="text-muted mb-4">Hệ thống đã cập nhật dữ liệu lên MongoDB Atlas. Bạn có thể
                                    tiếp tục thao tác bằng các nút bên dưới.</p>

                                <div class="d-grid gap-2">
                                    <a href="/" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                        <i class="bi bi-house-door"></i> Quay lại trang chủ
                                    </a>
                                    <button onclick="history.back()" class="btn btn-outline-success rounded-pill">
                                        <i class="bi bi-arrow-left"></i> Tiếp tục thao tác cũ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="footer">
                <%- include('footer') %>
            </div>
    </div>
</body>

<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>