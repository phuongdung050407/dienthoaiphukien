<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content">
                <div id="cottrai"></div>
                <div class="container-fluid py-4">
                    <% if (!session.quyenHan || session.quyenHan==3) { %>
                        <div class='container mt-5'>
                            <div class='alert alert-danger shadow-sm rounded-4 text-center py-5'>
                                <i class='bi bi-shield-lock-fill fs-1 d-block mb-3'></i>
                                <h4 class="fw-bold">TRUY CẬP BỊ TỪ CHỐI</h4>
                                <p>Bạn không có quyền truy cập vào khu vực quản lý này.</p>
                                <a href="/" class="btn btn-danger rounded-pill px-4 mt-3">Quay lại Trang chủ</a>
                            </div>
                        </div>
                        <% } else { %>

                            <div id="phangiua" class="p-3 bg-white rounded-4 shadow-sm">
                                <ul class="nav nav-tabs mb-4">
                                    <li class="nav-item">
                                        <a class="nav-link <%= type == 'dienthoai' ? 'active fw-bold' : '' %>"
                                            href="/sanpham/ql/dienthoai">
                                            <i class="bi bi-phone"></i> Quản lý Điện thoại
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link <%= type == 'phukien' ? 'active fw-bold' : '' %>"
                                            href="/sanpham/ql/phukien">
                                            <i class="bi bi-headset"></i> Quản lý Phụ kiện
                                        </a>
                                    </li>
                                </ul>

                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h3 class="text-primary fw-bold mb-0">
                                        <i class="bi bi-list-task"></i>
                                        <%= title %>
                                    </h3>
                                    <a href="/sanpham/them/<%= type %>"
                                        class="btn btn-success rounded-pill shadow-sm px-4 fw-bold">
                                        <i class="bi bi-plus-circle-fill"></i> THÊM <%= type=='dienthoai' ? 'ĐIỆN THOẠI'
                                            : 'PHỤ KIỆN' %> MỚI
                                    </a>
                                </div>

                                <div class="table-responsive rounded-4 border">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-dark">
                                            <tr style="background-color: #3839af !important;">
                                                <th class="ps-3">Mã ID</th>
                                                <th>Sản phẩm</th>
                                                <th>Hãng/Loại</th>
                                                <th>Giá bán</th>
                                                <th>Kho</th>
                                                <% if(type=='dienthoai' ) { %>
                                                    <th>Đã bán</th>
                                                    <% } %>
                                                        <th>Trạng thái</th>
                                                        <th class="text-center">Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (result && result.length> 0) { %>
                                                <% result.forEach(row=> { %>
                                                    <tr>
                                                        <td class="ps-3 text-muted small">#<%=
                                                                row._id.toString().substring(19) %>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                <img src="/images/<%= row.hinhAnh %>" width="45"
                                                                    height="45" class="me-2 rounded border shadow-sm"
                                                                    style="object-fit: contain;">
                                                                <div>
                                                                    <div class="fw-bold">
                                                                        <%= type=='dienthoai' ? row.tenDienThoai :
                                                                            row.tenPhuKien %>
                                                                    </div>
                                                                    <small class="text-muted">
                                                                        <%= row.boNho ? row.boNho : '' %>
                                                                    </small>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge <%= type == 'dienthoai' ? 'bg-primary' : 'bg-info text-dark' %>">
                                                                <%= type=='dienthoai' ? (row.maHangDienThoai ?
                                                                    row.maHangDienThoai.tenHangDienThoai : 'N/A' ) :
                                                                    (row.maLoaiPhuKien ?
                                                                    row.maLoaiPhuKien.tenLoaiPhuKien : 'N/A' ) %>
                                                            </span>
                                                        </td>
                                                        <td class="text-danger fw-bold">
                                                            <%= row.giaBan.toLocaleString() %> đ
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="fw-bold <%= row.soLuong < 5 ? 'text-danger' : 'text-dark' %>">
                                                                <%= row.soLuong %>
                                                            </span>
                                                        </td>
                                                        <% if(type=='dienthoai' ) { %>
                                                            <td class="text-center">
                                                                <%= row.daBan || 0 %>
                                                            </td>
                                                            <% } %>
                                                                <td>
                                                                    <% let status=row.maTrangThai ?
                                                                        row.maTrangThai.tenTrangThai : 'Đang bán' ; let
                                                                        statusClass=status.includes('Ngừng')
                                                                        ? 'text-danger' : 'text-success' ; %>
                                                                        <span class="fw-bold small <%= statusClass %>">
                                                                            <i class="bi bi-circle-fill"
                                                                                style="font-size: 8px;"></i>
                                                                            <%= status %>
                                                                        </span>
                                                                </td>
                                                                <td class="text-center">
                                                                    <div class="btn-group shadow-sm">
                                                                        <a href="/sanpham/sua/<%= type %>/<%= row._id %>"
                                                                            class="btn btn-sm btn-outline-primary"
                                                                            title="Sửa">
                                                                            <i class="bi bi-pencil-square"></i>
                                                                        </a>
                                                                        <a href="/sanpham/xoa/<%= type %>/<%= row._id %>"
                                                                            class="btn btn-sm btn-outline-danger"
                                                                            onclick="return confirm('Xóa sản phẩm này khỏi hệ thống?')"
                                                                            title="Xóa">
                                                                            <i class="bi bi-trash"></i>
                                                                        </a>
                                                                    </div>
                                                                </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="8" class="text-center py-5 text-muted">
                                                                    <i
                                                                        class="bi bi-database-exclamation fs-2 d-block mb-2"></i>
                                                                    Chưa có dữ liệu sản phẩm trong kho.
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>

                                <% if (totalPages> 1) { %>
                                    <nav class="mt-4">
                                        <ul class="pagination justify-content-center">
                                            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                                                <a class="page-link shadow-sm"
                                                    href="/sanpham/ql/<%= type %>?page=<%= page - 1 %>">
                                                    <i class="bi bi-chevron-left"></i>
                                                </a>
                                            </li>
                                            <% for(let i=1; i <=totalPages; i++) { %>
                                                <li class="page-item <%= page == i ? 'active' : '' %>">
                                                    <a class="page-link shadow-sm"
                                                        href="/sanpham/ql/<%= type %>?page=<%= i %>">
                                                        <%= i %>
                                                    </a>
                                                </li>
                                                <% } %>
                                                    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                                                        <a class="page-link shadow-sm"
                                                            href="/sanpham/ql/<%= type %>?page=<%= parseInt(page) + 1 %>">
                                                            <i class="bi bi-chevron-right"></i>
                                                        </a>
                                                    </li>
                                        </ul>
                                    </nav>
                                    <% } %>
                            </div>
                            <% } %>
                </div>
                <div id="cotphai"></div>
            </div>

            <div id="footer">
                <%- include('footer') %>
            </div>
    </div>
</body>

<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }

    .nav-tabs {
        border-bottom: 2px solid #dee2e6;
    }

    .nav-tabs .nav-item .nav-link {
        color: black !important;
        border: none;
        padding: 12px 20px;
        transition: all 0.3s ease;
        font-weight: 500;
        position: relative;
    }

    .nav-tabs .nav-item .nav-link:hover {
        color: #3839af;
        background-color: rgba(56, 57, 175, 0.05);
        border-radius: 10px 10px 0 0;
    }

    .nav-tabs .nav-item .nav-link.active {
        color: #3839af !important;
        background: none;
        font-weight: bold;
    }

    .nav-tabs .nav-item .nav-link.active::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background-color: #3839af;
        border-radius: 3px 3px 0 0;
    }

    .nav-tabs .nav-link i {
        margin-right: 8px;
        font-size: 1.1rem;
    }

    .table-responsive {
        min-height: 400px;
    }

    .table thead th {
        background-color: #3839af !important;
        border: none;
    }

    /* CSS cho thanh phân trang */
    .pagination .page-link {
        color: #3839af;
        border: 1px solid #dee2e6;
        padding: 8px 16px;
    }

    .pagination .page-item.active .page-link {
        background-color: #3839af;
        border-color: #3839af;
        color: white;
    }

    .pagination .page-link:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>