<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %> - MAPD Tech Space
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>

            <div id="content" class="container">
                <div id="cottrai"></div>
                <div id="phangiua" class="p-4 bg-white rounded-4 shadow-sm mt-3">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-primary"><i class="bi bi-person-bounding-box"></i> CHỈNH SỬA HỒ SƠ</h3>
                        <p class="text-muted small">Vui lòng xác nhận mật khẩu hiện tại để lưu các thay đổi</p>
                    </div>

                    <div class="row justify-content-center">
                        <div class="col-md-8">
                            <%- message %>

                                <form action="/taikhoan/sua-profile" method="POST"
                                    class="bg-light p-4 rounded-4 border">
                                    <div class="mb-4 text-center">
                                        <div class="avatar-placeholder d-inline-block bg-primary text-white rounded-circle shadow"
                                            style="width: 80px; height: 80px; line-height: 80px; font-size: 2rem;">
                                            <%= taikhoan.tenTaiKhoan.charAt(0).toUpperCase() %>
                                        </div>
                                        <p class="mt-2 fw-bold text-dark">@<%= taikhoan.tenDangNhap %>
                                        </p>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Họ và tên mới</label>
                                        <input type="text" name="tenTaiKhoan" class="form-control border-2"
                                            value="<%= taikhoan.tenTaiKhoan %>" required>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-danger">Mật khẩu hiện tại (Bắt buộc xác
                                            nhận)</label>
                                        <input type="password" name="matKhauCu"
                                            class="form-control border-danger border-2 shadow-sm"
                                            placeholder="Nhập mật khẩu hiện tại để lưu..." required>
                                    </div>

                                    <hr class="my-4 border-secondary">
                                    <p class="text-muted small italic"><i class="bi bi-shield-lock"></i> Đổi mật khẩu
                                        mới (Bỏ trống nếu không muốn thay đổi)</p>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold small">Mật khẩu mới</label>
                                            <input type="password" name="matKhauMoi" class="form-control"
                                                placeholder="Ít nhất 6 ký tự">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold small">Xác nhận mật khẩu mới</label>
                                            <input type="password" name="xacNhanMatKhauMoi" class="form-control"
                                                placeholder="Nhập lại mật khẩu mới">
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2 mt-4">
                                        <button type="submit"
                                            class="btn btn-primary btn-lg rounded-pill fw-bold shadow">
                                            <i class="bi bi-save2"></i> CẬP NHẬT HỒ SƠ
                                        </button>
                                        <a href="/taikhoan/profile"
                                            class="btn btn-link text-secondary text-decoration-none">Hủy bỏ và quay
                                            lại</a>
                                    </div>
                                </form>
                        </div>
                    </div>
                </div>
                <div id="cotphai"></div>
            </div>

            <%- include('footer') %>
    </div>
</body>
<style>
    .italic {
        font-style: italic;
    }

    .form-control:focus {
        border-color: #3839af;
        box-shadow: none;
    }

    .avatar-placeholder {
        text-transform: uppercase;
        font-weight: bold;
    }

    #phangiua {
        min-height: 600px;
    }
</style>

</html>