<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %> - MAPD Tech Space
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>
            <div id="content">
                <div class="container-fluid"
                    style="background-color: white !important; border-radius: 15px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-top: 20px;">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary fw-bold"><i
                                        class="bi bi-house-door-fill"></i> Trang chủ</a></li>
                            <li class="breadcrumb-item active">Kết quả tìm kiếm</li>
                        </ol>
                    </nav>

                    <div class="shadow-sm border-0 rounded-4 mb-4 bg-light">
                        <div class="card-body p-3">
                            <form action="/timkiem" method="GET" class="row g-2 align-items-center">
                                <input type="hidden" name="tukhoa" value="<%= tukhoa %>">

                                <div class="col-md-4">
                                    <select name="gia" class="form-select border-2 rounded-pill"
                                        onchange="this.form.submit()">
                                        <option value="">--- Tất cả mức giá ---</option>
                                        <option value="duoi5" <%=mucGia=='duoi5' ?'selected':'' %>>Dưới 5 triệu</option>
                                        <option value="5to10" <%=mucGia=='5to10' ?'selected':'' %>>5 - 10 triệu</option>
                                        <option value="tren10" <%=mucGia=='tren10' ?'selected':'' %>>Trên 10 triệu
                                        </option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <select name="sort" class="form-select border-2 rounded-pill"
                                        onchange="this.form.submit()">
                                        <option value="">--- Sắp xếp theo ---</option>
                                        <option value="gia_tang" <%=sapXep=='gia_tang' ?'selected':'' %>>Giá thấp đến
                                            cao</option>
                                        <option value="gia_giam" <%=sapXep=='gia_giam' ?'selected':'' %>>Giá cao đến
                                            thấp</option>
                                    </select>
                                </div>

                                <div class="col-md-4 d-flex gap-2">
                                    <button type="submit"
                                        class="btn btn-primary btn-sm rounded-pill px-3 fw-bold shadow-sm">
                                        <i class="bi bi-filter"></i> Lọc
                                    </button>
                                    <% if(mucGia !='' || sapXep !='' ) { %>
                                        <a href="/timkiem?tukhoa=<%= encodeURIComponent(tukhoa) %>"
                                            class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm">
                                            <i class="bi bi-arrow-counterclockwise"></i>Xóa lọc
                                        </a>
                                        <% } %>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold text-primary mb-0">Kết quả cho: "<%= tukhoa %>"</h3>
                        <span class="text-muted">Tìm thấy <strong>
                                <%= count %>
                            </strong> sản phẩm</span>
                    </div>

                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                        <% if (count> 0) { %>
                            <% result.forEach(row=> {
                                let giaGoc = row.giaGoc || 0;
                                let giaBan = row.giaBan;
                                let phanTram = (giaGoc > giaBan) ? Math.round(((giaGoc - giaBan)/giaGoc)*100) : 0;
                                %>
                                <div class='col'>
                                    <div class='card h-100 shadow-sm border-0 product-card position-relative bg-white'>
                                        <% if (phanTram> 0) { %>
                                            <span
                                                class="badge bg-danger position-absolute top-0 start-0 m-3 shadow-sm py-2 px-3 rounded-pill"
                                                style="z-index: 5;">
                                                <i class="bi bi-lightning-fill"></i> -<%= phanTram %>%
                                            </span>
                                            <% } %>
                                                <a href='/sanpham/sanpham_chitiet/<%= row.id %>/<%= row.loai %>'
                                                    class='text-decoration-none text-dark d-flex flex-column h-100'>
                                                    <div class="product-img-wrapper">
                                                        <img src='/images/<%= row.hinhAnh %>'
                                                            class='card-img-top product-img' alt="<%= row.ten %>">
                                                    </div>
                                                    <div
                                                        class='card-body text-center pt-0 flex-grow-1 d-flex flex-column'>
                                                        <h6 class='card-title fw-bold mb-2'>
                                                            <%= row.ten %>
                                                        </h6>
                                                        <div class="price-box mb-3">
                                                            <div class="text-danger fw-bold fs-5">
                                                                <%= giaBan.toLocaleString() %> đ
                                                            </div>
                                                            <% if (giaGoc> giaBan) { %>
                                                                <small class="text-muted text-decoration-line-through">
                                                                    <%= giaGoc.toLocaleString() %> đ
                                                                </small>
                                                                <% } %>
                                                        </div>
                                                        <div class="mt-auto">
                                                            <span class="badge bg-light text-secondary border small">
                                                                <i class="bi bi-tag-fill"></i>
                                                                <%= row.loai=='dienthoai' ? 'Điện thoại' : 'Phụ kiện' %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </a>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class='col-12 text-center py-5'>
                                            <h5><i class="bi bi-search"></i> Không tìm thấy sản phẩm phù hợp!</h5>
                                        </div>
                                        <% } %>
                    </div>

                    <% if (totalPages> 1) { %>
                        <nav class="mt-5">
                            <ul class="pagination justify-content-center shadow-sm">
                                <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link"
                                        href="/timkiem?tukhoa=<%= tukhoa %>&gia=<%= mucGia %>&sort=<%= sapXep %>&page=<%= page - 1 %>">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                <% for(let i=1; i <=totalPages; i++) { %>
                                    <li class="page-item <%= page == i ? 'active' : '' %>">
                                        <a class="page-link"
                                            href="/timkiem?tukhoa=<%= tukhoa %>&gia=<%= mucGia %>&sort=<%= sapXep %>&page=<%= i %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>
                                        <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                                            <a class="page-link"
                                                href="/timkiem?tukhoa=<%= tukhoa %>&gia=<%= mucGia %>&sort=<%= sapXep %>&page=<%= page + 1 %>">
                                                <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </li>
                            </ul>
                        </nav>
                        <% } %>
                </div>
            </div>
            <div id="cotphai"></div>
            <div id="footer">
                <%- include('footer') %>
            </div>
    </div>
</body>
<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }

    .product-card {
        transition: all 0.3s ease;
        border-radius: 20px !important;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.12) !important;
    }

    .product-img-wrapper {
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background-color: #fff;
    }

    .product-img {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        transition: transform 0.4s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.08);
    }

    .card-title {
        height: 3rem;
        overflow: hidden;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        font-size: 1.05rem;
        line-height: 1.5;
    }

    .price-box {
        min-height: 3.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .pagination .page-link {
        color: #3839af;
        border: 1px solid #dee2e6;
        padding: 10px 18px;
    }

    .pagination .page-item.active .page-link {
        background-color: #3839af;
        border-color: #3839af;
        color: white;
    }

    .pagination .page-link:hover {
        background-color: rgba(56, 57, 175, 0.05);
        color: #3839af;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 3rem;
    }

    .input-group-text {
        border-color: #dee2e6 !important;
    }

    .form-select {
        border-color: #dee2e6 !important;
    }

    .form-select:focus {
        border-color: #3839af !important;
        box-shadow: none !important;
    }

    .btn-sm {
        font-size: 0.85rem;
        padding-top: 5px;
        padding-bottom: 5px;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>