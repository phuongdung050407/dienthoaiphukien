<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Lỗi hệ thống - MAPD Tech Space</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-light">
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content" class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-6 text-center">
                        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                            <div class="card-header bg-danger text-white py-3">
                                <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill"></i>
                                    <%= title %>
                                </h4>
                            </div>
                            <div class="card-body p-5">
                                <div class="mb-4 fs-5 text-secondary">
                                    <%- message || "Đã có sự cố xảy ra. Vui lòng thử lại sau." %>
                                </div>

                                <div class="d-grid gap-2">
                                    <a href="/" class="btn btn-primary btn-lg rounded-pill fw-bold">
                                        <i class="bi bi-house-door"></i> Quay lại trang chủ
                                    </a>
                                    <button onclick="history.back()" class="btn btn-outline-secondary rounded-pill">
                                        <i class="bi bi-arrow-left"></i> Quay lại trang trước
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div id="footer">
                <%- include('footer') %>
            </div>
    </div>
</body>
<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {
        $('.btn-add-ajax').on('click', function (e) {
            e.preventDefault(); // Không cho trang web tải lại

            var sp_id = $(this).data('id');
            var sp_loai = $(this).data('loai');
            var nut_bam = $(this); // Lưu lại nút để đổi màu

            $.ajax({
                url: 'them_gio_hang.php',
                type: 'GET',
                data: { id: sp_id, loai: sp_loai },
                success: function (response) {
                    $('#cart-count').text(response);

                    // Hiệu ứng đổi màu nút để báo thành công
                    nut_bam.removeClass('btn-primary').addClass('btn-success');
                    nut_bam.html('<i class="bi bi-check-circle-fill"></i> Đã thêm');

                    // Sau 2 giây quay lại trạng thái cũ
                    setTimeout(function () {
                        nut_bam.removeClass('btn-success').addClass('btn-primary');
                        nut_bam.html('<i class="bi bi-cart-plus"></i> Thêm vào giỏ');
                    }, 2000);
                }
            });
        });
    });
</script>

</html>