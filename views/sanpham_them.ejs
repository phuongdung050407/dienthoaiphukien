<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %> - MAPD Tech Space
    </title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div id="khungtrang">
        <%- include('header') %>
            <div id="sticky-menu-wrapper">
                <div class="custom-sticky-menu">
                    <%- include('menungang') %>
                </div>
            </div>

            <div id="content" class="p-3">
                <div class="container py-4">
                    <form action="/sanpham/them/<%= type %>" method="POST">
                        <div class="card shadow border-0 border-start border-success border-5">
                            <div class="card-header bg-white text-success">
                                <h5 class="mb-0 fw-bold">
                                    <i class="bi bi-plus-circle-fill"></i> THÊM MỚI <%= (type=='dienthoai'
                                        ? 'ĐIỆN THOẠI' : 'PHỤ KIỆN' ) %>
                                </h5>
                            </div>
                            <div class="card-body p-4">
                                <div class="row">
                                    <div class="col-md-7">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Tên sản phẩm</label>
                                            <input type="text"
                                                name="<%= (type == 'dienthoai' ? 'tenDienThoai' : 'tenPhuKien') %>"
                                                class="form-control" placeholder="Nhập tên sản phẩm..." required>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Tên file hình ảnh (Trong
                                                public/images)</label>
                                            <input type="text" name="hinhAnh" id="hinhAnhInput" class="form-control"
                                                placeholder="VD: iphone15.jpg" required oninput="previewLocalImage()">

                                            <div id="imagePreviewContainer" class="mt-3">
                                                <label class="small text-muted mb-2">Xem trước hình ảnh:</label>
                                                <div id="previewBox"
                                                    class="border rounded d-flex align-items-center justify-content-center bg-white shadow-sm"
                                                    style="height: 250px; overflow: hidden; border-style: dashed !important;">
                                                    <i class="bi bi-image text-muted fs-1" id="placeholderIcon"></i>
                                                    <img src="" id="imgShow" class="d-none w-100 h-100"
                                                        style="object-fit: contain;">
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Mô tả sản phẩm</label>
                                            <textarea name="moTa" class="form-control" rows="6"
                                                placeholder="Thông số kỹ thuật, đặc điểm nổi bật..."></textarea>
                                        </div>
                                    </div>

                                    <div class="col-md-5">
                                        <div class="card p-3 bg-light border-0 mb-3 shadow-sm rounded-4">
                                            <div class="row">
                                                <div class="col-6 mb-3">
                                                    <label class="form-label fw-bold small">GIÁ GỐC (VNĐ)</label>
                                                    <input type="number" name="giaGoc" class="form-control" value="0"
                                                        required>
                                                </div>
                                                <div class="col-6 mb-3">
                                                    <label class="form-label fw-bold small text-danger">GIÁ BÁN
                                                        (VNĐ)</label>
                                                    <input type="number" name="giaBan" class="form-control"
                                                        placeholder="VNĐ" required>
                                                </div>
                                            </div>

                                            <% if(type=='dienthoai' ) { %>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold small">HÃNG SẢN XUẤT</label>
                                                    <select class="form-select border-2" name="maHangDienThoai"
                                                        required>
                                                        <% dsHangDT.forEach(h=> { %>
                                                            <option value="<%= h._id %>">
                                                                <%= h.tenHangDienThoai %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="row">
                                                    <div class="col-6 mb-3">
                                                        <label class="form-label fw-bold small">BỘ NHỚ</label>
                                                        <input type="text" name="boNho" class="form-control"
                                                            placeholder="VD: 128GB">
                                                    </div>
                                                    <div class="col-6 mb-3">
                                                        <label class="form-label fw-bold small">PIN</label>
                                                        <input type="text" name="dungLuongPin" class="form-control"
                                                            placeholder="VD: 5000mAh">
                                                    </div>
                                                </div>
                                                <% } else { %>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold small">LOẠI PHỤ KIỆN</label>
                                                        <select name="maLoaiPhuKien" class="form-select border-2">
                                                            <% dsLoaiPK.forEach(l=> { %>
                                                                <option value="<%= l._id %>">
                                                                    <%= l.tenLoaiPhuKien %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold small">THƯƠNG HIỆU PHỤ
                                                            KIỆN</label>
                                                        <select name="maHangPhuKien" class="form-select border-2">
                                                            <% dsHangPK.forEach(h=> { %>
                                                                <option value="<%= h._id %>">
                                                                    <%= h.tenHangPhuKien %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                    <% } %>

                                                        <div class="row">
                                                            <div class="col-6 mb-3">
                                                                <label class="form-label fw-bold small">SỐ LƯỢNG
                                                                    KHO</label>
                                                                <input type="number" name="soLuong" class="form-control"
                                                                    value="10" required>
                                                            </div>
                                                            <div class="col-6 mb-3">
                                                                <label class="form-label fw-bold small">TRẠNG
                                                                    THÁI</label>
                                                                <select name="maTrangThai" class="form-select border-2">
                                                                    <% dsTrangThai.forEach(tt=> { %>
                                                                        <option value="<%= tt._id %>">
                                                                            <%= tt.tenTrangThai %>
                                                                        </option>
                                                                        <% }) %>
                                                                </select>
                                                            </div>
                                                        </div>
                                        </div>

                                        <div class="d-grid gap-2">
                                            <button type="submit"
                                                class="btn btn-success btn-lg fw-bold shadow-sm py-3 rounded-pill">
                                                <i class="bi bi-cloud-arrow-up-fill"></i> LƯU SẢN PHẨM MỚI
                                            </button>
                                            <a href="/sanpham/ql/<%= type %>"
                                                class="btn btn-outline-secondary rounded-pill">QUAY LẠI</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div id="footer">
                <%- include('footer') %>
            </div>
    </div>

    <script>
        // Hàm hiển thị ảnh preview từ folder nội bộ
        function previewLocalImage() {
            const fileName = document.getElementById('hinhAnhInput').value;
            const imgShow = document.getElementById('imgShow');
            const placeholder = document.getElementById('placeholderIcon');

            if (fileName.trim() !== "") {
                imgShow.src = "/images/" + fileName;
                imgShow.classList.remove('d-none');
                placeholder.classList.add('d-none');
            } else {
                imgShow.classList.add('d-none');
                placeholder.classList.remove('d-none');
            }
        }
    </script>
</body>
<style>
    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #fff;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #khungtrang {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    #header,
    #sticky-menu-wrapper,
    #footer {
        flex: none;
    }

    #content {
        flex: 1 0 auto;
    }

    html,
    body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #footer {
        flex-shrink: 0;
    }

    .menu-ngang-container {
        margin-top: 0 !important;
    }

    .custom-sticky-menu .nav-link {
        color: #3839af !important;
        font-weight: 600;
        transition: all 0.3s ease;
        background: transparent !important;
    }

    .custom-sticky-menu .nav-link:hover {
        color: white !important;
        background-color: #3839af !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .nav-link.active {
        background-color: #3839af !important;
        color: white !important;
        border-radius: 8px;
    }

    .custom-sticky-menu .dropdown-menu {
        border: none;
        border-top: 3px solid #3839af;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .custom-sticky-menu .dropdown-item:hover {
        background-color: rgba(56, 57, 175, 0.1);
        color: #3839af !important;
        padding-left: 20px;
        transition: all 0.2s;
    }

    #sticky-menu-wrapper {
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: white;
        padding: 5px 0;
    }

    #content {
        display: flow-root;
        width: 100%;
        min-height: 600px;
        height: auto !important;
        padding-bottom: 50px;
        background-color: #ffffff;
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</html>